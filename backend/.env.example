# Backend runtime config. Copy to `backend/.env` and fill in real values.
# Values here MUST stay consistent with the root /.env (Postgres credentials).

DATABASE_URL="postgresql://retropad:change_me@localhost:5432/retropad?schema=public"

# JWT secrets: at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET="change_me_at_least_32_characters_long_random_string"
JWT_EXPIRES_IN="15min"
JWT_REFRESH_SECRET="change_me_at_least_32_characters_long_random_string"
JWT_REFRESH_EXPIRES_IN="30d"

NODE_ENV="development"
# COOKIE_DOMAIN=
